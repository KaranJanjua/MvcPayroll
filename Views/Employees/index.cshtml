@model List<Employee>
@{
    ViewData["Title"] = "Employee";
}
<h2>@ViewData["Title"]</h2>
<a asp-controller="Employees" asp-action="Create" class="btn btn-primary mb-3">+ Add Employee</a>
<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Department</th>
            <th>Office</th>
            <th>Location</th>
            <th>Annual Salary</th>
            <th>Pay Frequency</th>
            <th>Email</th>
            <th>Active</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var employee in Model)
        {
            <tr>
                <td>@employee.Id</td>
                <td>@employee.Name</td>
                <td>@employee.Department</td>
                <td>@employee.Office</td>
                <td>@employee.Location</td>
                <td>@employee.AnnualSalary.ToString("C")</td>
                <td>@employee.PayFrequency</td>
                <td>@employee.Email</td>
                <td>@(employee.IsActive ? "Yes" : "No")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@employee.Id" 
                    class="btn btn-sm btn-warning">Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>